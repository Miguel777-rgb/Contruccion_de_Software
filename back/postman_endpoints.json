{
  "info": {
    "name": "API Construcción de Software",
    "description": "Endpoints para el sistema de usuarios y tareas",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Tareas",
      "item": [
        {
          "name": "1. Obtener todas las tareas (con paginación)",
          "request": {
            "method": "GET",
            "url": "http://127.0.0.1:5000/tasks?page=1&limit=20",
            "description": "Obtiene todas las tareas activas (no soft-deleted) con paginación. Por defecto: page=1, limit=20 (máximo 100)"
          }
        },
        {
          "name": "1b. Obtener tareas con búsqueda",
          "request": {
            "method": "GET",
            "url": "http://127.0.0.1:5000/tasks?query=DB&page=1&limit=10",
            "description": "Busca tareas cuyo contenido contenga 'DB' (case-insensitive). Utiliza LIKE para coincidencias parciales."
          }
        },
        {
          "name": "2. Obtener tarea por ID",
          "request": {
            "method": "GET",
            "url": "http://127.0.0.1:5000/tasks/1",
            "description": "Obtiene una tarea específica por su ID. No devuelve tareas soft-deleted."
          }
        },
        {
          "name": "3. Crear tarea",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"content\": \"Nueva tarea\",\n    \"done\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "http://127.0.0.1:5000/tasks",
            "description": "Crea una nueva tarea en la base de datos MySQL. La tarea se guarda con timestamps UTC timezone-aware."
          }
        },
        {
          "name": "4. Actualizar tarea (marcar como completada)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"content\": \"Tarea actualizada\",\n    \"done\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "http://127.0.0.1:5000/tasks/1",
            "description": "Actualiza el contenido y estado de una tarea. No se puede actualizar tareas soft-deleted."
          }
        },
        {
          "name": "5. Eliminar tarea (Soft Delete)",
          "request": {
            "method": "DELETE",
            "url": "http://127.0.0.1:5000/tasks/1",
            "description": "Realiza soft delete: marca la tarea con deleted_at timestamp en lugar de borrarla. Los datos se conservan en la BD para auditoría."
          }
        }
      ]
    },
    {
      "name": "Usuarios",
      "item": [
        {
          "name": "1. Obtener todos los usuarios",
          "request": {
            "method": "GET",
            "url": "http://127.0.0.1:5000/users"
          }
        },
        {
          "name": "2. Obtener usuario por ID",
          "request": {
            "method": "GET",
            "url": "http://127.0.0.1:5000/users/1"
          }
        },
        {
          "name": "3. Crear Usuario (Ejemplo genérico)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Juan\",\n    \"lastname\": \"Pérez\",\n    \"address\": {\n        \"city\": \"Madrid\",\n        \"country\": \"España\",\n        \"postal_code\": \"28001\"\n    }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "http://127.0.0.1:5000/users"
          }
        },
        {
          "name": "4. Actualizar usuario",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Juan Actualizado\",\n    \"lastname\": \"Pérez Actualizado\",\n    \"address\": {\n        \"city\": \"Barcelona\",\n        \"country\": \"España\",\n        \"postal_code\": \"08001\"\n    }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "http://127.0.0.1:5000/users/1"
          }
        },
        {
          "name": "5. Eliminar usuario",
          "request": {
            "method": "DELETE",
            "url": "http://127.0.0.1:5000/users/1"
          }
        }
      ]
    },
    {
      "name": "Misceláneos",
      "item": [
        {
          "name": "1. Home",
          "request": {
            "method": "GET",
            "url": "http://127.0.0.1:5000/"
          }
        },
        {
          "name": "2. About",
          "request": {
            "method": "GET",
            "url": "http://127.0.0.1:5000/about"
          }
        },
        {
          "name": "3. Hello - Igor",
          "request": {
            "method": "GET",
            "url": "http://127.0.0.1:5000/hello/Igor"
          }
        }
      ]
    }
  ]
}
